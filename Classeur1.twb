      <column caption='Crypto Key (Dim Crypto)' datatype='string' name='[CRYPTO_KEY (DIM_CRYPTO)]' role='dimension' type='nominal' />
      <column caption='Crypto Key' datatype='string' name='[CRYPTO_KEY]' role='dimension' type='nominal' />
      <column caption='Métrique Temporelle Dynamique' datatype='real' name='[Calculation_0412055233314822]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Paramètre 0412055232614405]&#13;&#10;    WHEN &quot;Prix&quot; THEN SUM([PRICE_USD])&#13;&#10;    WHEN &quot;Volume&quot; THEN SUM([VOLUME_USD])&#13;&#10;    WHEN &quot;Market Cap&quot; THEN SUM([MARKET_CAP_USD])&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Week' datatype='integer' name='[Calculation_0947791863861248]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;week&apos;, [FULL_DATE])' />
      </column>
      <column caption='Filtre Crypto Liaison' datatype='boolean' name='[Calculation_1436525860265986]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[SYMBOL] = [Parameters].[Paramètre 0412055230013442]' />
      </column>
      <column caption='Volume_MarketCap_Ratio' datatype='real' name='[Calculation_1436525902651395]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([VOLUME_USD]) / SUM([MARKET_CAP_USD])' />
      </column>
      <column caption='7_Day_Price_Change' datatype='real' name='[Calculation_1436525903417348]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([PRICE_USD])) - LOOKUP(ZN(SUM([PRICE_USD])), -7)) / LOOKUP(ZN(SUM([PRICE_USD])), -7)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Relative_Performance' datatype='real' name='[Calculation_1436525903544325]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([PRICE_USD]) / LOOKUP(SUM([PRICE_USD]), FIRST())'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Fleche' datatype='string' name='[Calculation_1436526178721798]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PCT_CHANGE_24H] &gt; 0 THEN &quot;▲&quot; ELSE &quot;▼&quot; END' />
      </column>
      <column caption='Vide' datatype='string' name='[Calculation_1436526191788039]' role='dimension' type='nominal'>
